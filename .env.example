# Discord Bot
DISCORD_TOKEN=your_discord_bot_token
OWNER_ID=your_discord_user_id

# Dashboard
DASHBOARD_PORT=3000
# Public HTTPS origin for OAuth callbacks, e.g. https://toro.example.com
TORO_PUBLIC_URL=https://bot.yeonnnn.xyz
# Backward-compatible aliases for TORO_PUBLIC_URL; normally leave blank
PUBLIC_BASE_URL=
DASHBOARD_PUBLIC_URL=
DASHBOARD_SECRET=replace_with_openssl_rand_hex_32

# AI provider selection: codex / google / openai / anthropic
# codex uses the Codex CLI login session mounted at CODEX_HOME, not OPENAI_API_KEY.
AI_PROVIDER=codex
CODEX_MODEL=codex-cli-default
CODEX_HOME=/codex
# Host path mounted to CODEX_HOME by docker-compose; keep secrets outside git
CODEX_HOME_HOST=./codex
# Optional: absolute Codex binary path. If blank, uses `codex` from PATH.
CODEX_BIN=
# Optional: working directory for Codex chat replies. Defaults to OS temp dir.
CODEX_WORKDIR=
CODEX_TIMEOUT_MS=180000
# Optional: separate timeout for /draw Codex image generation
CODEX_IMAGE_TIMEOUT_MS=300000
# Optional: set 1 to run Codex through `npx -y @openai/codex` when no CODEX_BIN is set
CODEX_USE_NPX=0

# Google Gemini fallback / image / RAG
GOOGLE_API_KEY=your_google_api_key
GOOGLE_MODEL=gemini-3.1-flash-lite-preview
GOOGLE_FALLBACK_MODEL=gemini-3.1-flash-lite-preview
GOOGLE_IMAGE_MODEL=gemini-2.5-flash-image-preview

# Anthropic (AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI API (AI_PROVIDER=openai) — separate from Codex CLI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=gpt-image-1.5
TORO_TTS_PROVIDER=edge
EDGE_TTS_VOICE=
EDGE_TTS_PYTHON=python3
EDGE_TTS_TIMEOUT_MS=60000
EDGE_TTS_RATE=
EDGE_TTS_PITCH=
EDGE_TTS_VOLUME=
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Database
DATABASE_URL=file:/app/data/toro.db

# Security
TOKEN_ENCRYPTION_KEY=replace_with_openssl_rand_hex_32
# Optional: production auto-generates/reads this when TOKEN_ENCRYPTION_KEY is blank
TOKEN_ENCRYPTION_KEY_FILE=/app/data/token-encryption.key

# Vault integration
VAULT_PATH=/vault

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=

# Generate secrets, for example:
#   openssl rand -hex 32

# RAG embeddings: google=Gemini embedding, openai=OpenAI text embedding
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-001
