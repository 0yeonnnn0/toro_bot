DISCORD_TOKEN=replace_me_discord_token
OWNER_ID=your_discord_user_id
DASHBOARD_PORT=3000
REPLY_CHANCE=0.08
DASHBOARD_SECRET=replace_with_long_random_dashboard_secret

# AI 프로바이더 선택: codex / google / openai / anthropic
# codex는 OPENAI_API_KEY가 아니라 Codex CLI 로그인 세션(CODEX_HOME/auth.json 또는 keyring)을 사용한다.
AI_PROVIDER=codex
CODEX_MODEL=codex-cli-default
CODEX_HOME=/codex
CODEX_TIMEOUT_MS=180000

# Anthropic (AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI API (AI_PROVIDER=openai) — Codex CLI와 별개
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Google Gemini (AI_PROVIDER=google)
GOOGLE_API_KEY=your_google_api_key
GOOGLE_MODEL=gemini-3.1-flash-lite-preview
GOOGLE_IMAGE_MODEL_FLASH=gemini-2.5-flash-image-preview
GOOGLE_IMAGE_MODEL_PRO=gemini-2.5-flash-image-preview
# Database
DATABASE_URL=file:/app/data/toro.db

# Security
TOKEN_ENCRYPTION_KEY=replace_with_32_char_secret_key

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/oauth/callback

# TORO team behavior
TORO_DEFAULT_TEAM_MODE=required
TORO_ALLOW_AUTO_TEAM_CREATE=false

# Generate secrets, for example:
#   openssl rand -hex 32
