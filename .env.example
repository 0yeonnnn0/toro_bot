DISCORD_TOKEN=your_discord_bot_token
OWNER_ID=your_discord_user_id
DASHBOARD_PORT=3000
REPLY_CHANCE=0.08
DASHBOARD_SECRET=changeme

# AI 프로바이더 선택: anthropic / openai / google
AI_PROVIDER=anthropic

# Anthropic (AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Google Gemini (AI_PROVIDER=google)
GOOGLE_API_KEY=your_google_api_key
GOOGLE_MODEL=gemini-2.0-flash
# Database
DATABASE_URL=file:/app/data/toro.db

# Security
TOKEN_ENCRYPTION_KEY=replace_with_32_char_secret_key

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/oauth/callback

# TORO team behavior
TORO_DEFAULT_TEAM_MODE=required
TORO_ALLOW_AUTO_TEAM_CREATE=false
